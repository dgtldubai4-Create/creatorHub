# --- Database ---------------------------------------------------------------
# Local dev (SQLite). For production on Vercel/Netlify, swap to a hosted
# Postgres (Neon / Supabase / Vercel Postgres) and change the provider in
# prisma/schema.prisma to "postgresql":
#   DATABASE_URL="postgresql://user:pass@host:5432/dabur_creator_hub"
DATABASE_URL="file:./dev.db"

# --- NextAuth ---------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-32-byte-string"
# Local dev URL. On Vercel this is inferred automatically.
NEXTAUTH_URL="http://localhost:3000"
